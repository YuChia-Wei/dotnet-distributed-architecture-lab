{
  "Messaging": {
    "Profile": "InMemory",
    "Kafka": {
      "ConnectionString": "localhost:9092"
    },
    "RabbitMq": {
      "ConnectionString": "amqp://guest:guest@localhost:5672"
    },
    "OutboxRelay": {
      "Enabled": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
